# ════════════════════════════════════════════════
# 100X CONTENT AGENT — CẤU HÌNH API KEYS
# ════════════════════════════════════════════════
# Hướng dẫn: Điền key thật vào các dòng bên dưới, sau đó lưu lại.
# KHÔNG chia sẻ file .env lên GitHub hay cho bất kỳ ai.
# ════════════════════════════════════════════════

# ── TÙY CHỌN (không có vẫn chạy được, nhưng giảm tính năng) ──

# 2. Gemini API Key — AI viết nội dung (/vietbai, /research_ideas)
#    Lấy tại: https://aistudio.google.com → Get API Key (Miễn phí)
#    Không có: lệnh /vietbai và /research_ideas không hoạt động
GEMINI_API_KEY="dien_gemini_key_cua_ban_vao_day"

# 3. Pexels API Key — Kho video B-Roll & ảnh (Miễn phí)
#    Lấy tại: https://www.pexels.com/api/
#    Không có: chỉ dùng được video local trong media-input/background-video/
PEXELS_API_KEY="dien_pexels_key_cua_ban_vao_day"

# 4. ElevenLabs API Key — Giọng đọc AI cho Video Reels
#    Lấy tại: https://elevenlabs.io → Profile → API Keys
#    Không có: video tạo được nhưng không có voiceover
ELEVENLABS_API_KEY="dien_elevenlabs_key_cua_ban_vao_day"

# 4.1 ElevenLabs Voice ID — ID giọng đọc ưa thích (tùy chọn)
#     Vào Voice Library → chọn giọng → copy Voice ID
#     Để trống = dùng giọng mặc định
ELEVENLABS_VOICE_ID=""
